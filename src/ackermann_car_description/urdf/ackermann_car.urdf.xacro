<?xml version="1.0"?>
<robot name="ackermann_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- controllers.yaml 경로 — launch 파일에서 절대 경로로 주입 -->
  <xacro:arg name="controllers_yaml" default=""/>

  <!-- ============================================================
       Properties
  ============================================================ -->
  <xacro:property name="wheel_r"      value="0.065"/>
  <xacro:property name="wheel_w"      value="0.040"/>
  <xacro:property name="wheelbase"    value="0.280"/>
  <xacro:property name="track"        value="0.260"/>
  <xacro:property name="body_l"       value="0.440"/>
  <xacro:property name="body_w"       value="0.200"/>
  <xacro:property name="body_h"       value="0.140"/>
  <xacro:property name="chassis_mass" value="1.5"/>
  <xacro:property name="wheel_mass"   value="0.1"/>

  <!-- ============================================================
       base_footprint  (ground projection, child of base_link)
  ============================================================ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_footprint"/>
    <origin xyz="0 0 ${-wheel_r}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       base_link — simple box chassis
       Origin: wheel-axle height, midpoint between axles, centre.
  ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
      <material name="chassis_blue"><color rgba="0.15 0.35 0.75 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia ixx="0.006" ixy="0" ixz="0"
               iyy="0.025" iyz="0"
               izz="0.030"/>
    </inertial>
  </link>

  <!-- ============================================================
       Wheel macro  (cylinder, rolling axis = local Y)
  ============================================================ -->
  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="wheel_rubber"><color rgba="0.22 0.20 0.17 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.000120" ixy="0" ixz="0"
                 iyy="0.000211" iyz="0"
                 izz="0.000120"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- Front-Left -->
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="front_left_steer_link"/>
    <origin xyz="${wheelbase/2} ${track/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.50" upper="0.50" effort="5" velocity="2"/>
    <dynamics damping="0.1"/>
  </joint>

  <link name="front_left_steer_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-6"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer_link"/>
    <child  link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="15.0"/>
    <dynamics damping="0.01"/>
  </joint>
  <xacro:wheel_link name="front_left_wheel"/>

  <!-- Front-Right -->
  <joint name="front_right_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="front_right_steer_link"/>
    <origin xyz="${wheelbase/2} ${-track/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.50" upper="0.50" effort="5" velocity="2"/>
    <dynamics damping="0.1"/>
  </joint>

  <link name="front_right_steer_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="5e-6" ixy="0" ixz="0" iyy="5e-6" iyz="0" izz="5e-6"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer_link"/>
    <child  link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="15.0"/>
    <dynamics damping="0.01"/>
  </joint>
  <xacro:wheel_link name="front_right_wheel"/>

  <!-- Rear-Left -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_left_wheel"/>
    <origin xyz="${-wheelbase/2} ${track/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="15.0"/>
    <dynamics damping="0.01"/>
  </joint>
  <xacro:wheel_link name="rear_left_wheel"/>

  <!-- Rear-Right -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_right_wheel"/>
    <origin xyz="${-wheelbase/2} ${-track/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="15.0"/>
    <dynamics damping="0.01"/>
  </joint>
  <xacro:wheel_link name="rear_right_wheel"/>

  <!-- ============================================================
       LiDAR — roof centre
  ============================================================ -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <!-- wheel_r=0.065 이므로 0.13m 이상이어야 휠 상단 위를 스캔 -->
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.050"/></geometry>
      <material name="lidar_red"><color rgba="0.85 0.15 0.10 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.050"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- ============================================================
       Camera — front face of chassis
  ============================================================ -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${body_l/2 + 0.015} 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.030 0.060 0.030"/></geometry>
      <material name="camera_yellow"><color rgba="0.95 0.80 0.10 1.0"/></material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="camera_optical_frame"/>

  <!-- ============================================================
       Gazebo 색상 — URDF <material>은 RViz 전용, Gazebo는 별도 태그 필요
  ============================================================ -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="front_left_steer_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="front_right_steer_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="camera_link">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <!-- ============================================================
       Wheel physics + 색상
  ============================================================ -->
  <xacro:macro name="wheel_physics" params="link">
    <gazebo reference="${link}">
      <!-- 고무 타이어: 다크 챠콜 + 극저 specular(무광) + 약간 warm 브라운 톤 -->
      <visual>
        <material>
          <ambient>0.12 0.11 0.09 1.0</ambient>
          <diffuse>0.22 0.20 0.17 1.0</diffuse>
          <specular>0.02 0.02 0.02 1.0</specular>
          <emissive>0.0 0.0 0.0 1.0</emissive>
        </material>
      </visual>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>1.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>1.0</maxVel>
      <fdir1>1 0 0</fdir1>
    </gazebo>
  </xacro:macro>

  <xacro:wheel_physics link="front_left_wheel"/>
  <xacro:wheel_physics link="front_right_wheel"/>
  <xacro:wheel_physics link="rear_left_wheel"/>
  <xacro:wheel_physics link="rear_right_wheel"/>

  <!-- ============================================================
       2-D LiDAR (360°)
  ============================================================ -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min><max>10.0</max><resolution>0.01</resolution>
        </range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================================================
       RGB Camera (640x480)
  ============================================================ -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="camera_sensor">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <camera name="front_camera">
        <horizontal_fov>1.5708</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>20.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================================================
       ros2_control hardware interface
  ============================================================ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <!-- 앞바퀴 조향: position 명령 -->
    <joint name="front_left_steer_joint">
      <command_interface name="position">
        <param name="min">-0.5</param>
        <param name="max">0.5</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_steer_joint">
      <command_interface name="position">
        <param name="min">-0.5</param>
        <param name="max">0.5</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- 앞바퀴 휠: passive (state만, 오도메트리용) -->
    <joint name="front_left_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- 뒷바퀴: velocity 명령 (주 구동)
         vel_kp/ki/kd는 <joint> 직계 자식 <param>으로 지정해야
         joint_info.parameters에 저장되어 extractPID에 인식됨.
         (command_interface 내부 param은 command_interface.parameters에
          저장되므로 extractPID에 감지되지 않음) -->
    <joint name="rear_left_wheel_joint">
      <param name="vel_kp">0.1</param>
      <param name="vel_ki">0.0</param>
      <param name="vel_kd">0.0</param>
      <command_interface name="velocity">
        <param name="min">-15</param>
        <param name="max">15</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <param name="vel_kp">0.1</param>
      <param name="vel_ki">0.0</param>
      <param name="vel_kd">0.0</param>
      <command_interface name="velocity">
        <param name="min">-15</param>
        <param name="max">15</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ============================================================
       gazebo_ros2_control 플러그인
  ============================================================ -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(arg controllers_yaml)</parameters>
    </plugin>
  </gazebo>

</robot>
